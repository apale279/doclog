rules_version = '2';

// DOCLOG — accesso consentito solo a utenti autenticati.
// I profili utente (rank) sono scrivibili solo dagli ADMIN: niente auto-promozione.
service cloud.firestore {
  match /databases/{database}/documents {

    match /manifestazioni/{mid} {

      function isSignedIn() {
        return request.auth != null;
      }
      function profilePath() {
        return /databases/$(database)/documents/manifestazioni/$(mid)/userProfiles/$(request.auth.uid);
      }
      function isAdmin() {
        return isSignedIn()
          && exists(profilePath())
          && get(profilePath()).data.rank == 'ADMIN';
      }
      // Bootstrap: l'admin di default può sempre scrivere il proprio profilo.
      function isBootstrapAdmin() {
        return isSignedIn() && request.auth.token.email == 'admin@doclog.it';
      }

      // Documento manifestazione (tenant) — solo loggati.
      allow read, write: if isSignedIn();

      // Profili utente: lettura ai loggati, scrittura solo agli ADMIN.
      match /userProfiles/{uid} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isBootstrapAdmin();
      }

      // Dati operativi e impostazioni: solo utenti autenticati.
      match /pazienti/{document=**} { allow read, write: if isSignedIn(); }
      match /settings/{document=**} { allow read, write: if isSignedIn(); }
      match /note_diario/{document=**} { allow read, write: if isSignedIn(); }
      match /eventi/{document=**} { allow read, write: if isSignedIn(); }
      match /missioni/{document=**} { allow read, write: if isSignedIn(); }
      match /mezzi/{document=**} { allow read, write: if isSignedIn(); }
      match /pma_firma_ipad/{document=**} { allow read, write: if isSignedIn(); }
      match /pma_firma_coda/{document=**} { allow read, write: if isSignedIn(); }
      match /telegram_users/{document=**} { allow read, write: if isSignedIn(); }

      // Token firma guest (QR senza login): lettura/scrittura firma solo se attivo.
      match /firma_guest_token/{tokenId} {
        function tokenActive() {
          return resource.data.active == true;
        }
        function guestFirmaUpdateOnly() {
          return request.auth == null
            && tokenActive()
            && request.resource.data.active == true
            && request.resource.data.pazienteDocId == resource.data.pazienteDocId
            && request.resource.data.pmaId == resource.data.pmaId
            && request.resource.data.patientLabel == resource.data.patientLabel
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firma_paziente_base64', 'firma_saved_at'])
            && request.resource.data.firma_paziente_base64 is string
            && request.resource.data.firma_paziente_base64.size() <= 700000;
        }
        allow read: if tokenActive();
        allow create, update: if isSignedIn();
        allow update: if guestFirmaUpdateOnly();
        allow delete: if isSignedIn();
      }
    }
  }
}
